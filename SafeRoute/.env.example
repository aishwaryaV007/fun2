# SafeRoute Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# BACKEND SERVER CONFIGURATION
# ============================================================================

# Backend host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database paths (development)
DATABASE_URL=sqlite:///./data/safe_routes.db
SOS_DATABASE_URL=sqlite:///./data/sos_alerts.db
CRIME_DATABASE_URL=sqlite:///./data/crime_reports.db

# PostgreSQL connection string (production - optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/saferoute_db

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# API Keys
SAFETY_API_KEY=dev-key-change-in-production
ADMIN_API_KEY=admin-key-change-in-production
ENFORCE_ADMIN_API_KEY=false

# JWT Secret (for future authentication)
JWT_SECRET=your-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# GOOGLE MAPS CONFIGURATION
# ============================================================================

# Google Maps API Key (for admin dashboard and mobile app)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Regex pattern for additional CORS origins (optional)
CORS_ALLOWED_ORIGIN_REGEX=.*localhost.*

# ============================================================================
# WEBSOCKET CONFIGURATION
# ============================================================================

# WebSocket settings
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_HEARTBEAT_TIMEOUT=60
WEBSOCKET_MAX_CONNECTIONS=1000

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================

# Route calculation rate limiting
ROUTE_RATE_LIMIT_REQUESTS=100
ROUTE_RATE_LIMIT_WINDOW_SECONDS=60

# SOS alert rate limiting
SOS_RATE_LIMIT_REQUESTS=10
SOS_RATE_LIMIT_WINDOW_SECONDS=300

# Admin read rate limiting
ADMIN_READ_RATE_LIMIT_REQUESTS=1000
ADMIN_READ_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# MOBILE APP CONFIGURATION
# ============================================================================

# Backend API URL for mobile app
MOBILE_BACKEND_URL=http://localhost:8000
MOBILE_WS_URL=ws://localhost:8000

# Location services
LOCATION_ACCURACY_METERS=10
LOCATION_UPDATE_INTERVAL_MS=5000

# ============================================================================
# ADMIN DASHBOARD CONFIGURATION
# ============================================================================

# Backend API URL for admin dashboard
ADMIN_BACKEND_URL=http://localhost:8000
ADMIN_WS_URL=ws://localhost:8000

# Admin refresh intervals (milliseconds)
HEATMAP_REFRESH_INTERVAL_MS=60000
ALERT_REFRESH_INTERVAL_MS=5000
ANALYTICS_REFRESH_INTERVAL_MS=30000

# ============================================================================
# MONITORING AND LOGGING
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentry configuration (optional)
SENTRY_DSN=

# DataDog configuration (optional)
DATADOG_API_KEY=

# ============================================================================
# GACHIBOWLI ROUTING CONFIGURATION
# ============================================================================

# Center coordinates
GACHIBOWLI_CENTER_LAT=17.4435
GACHIBOWLI_CENTER_LNG=78.3484
GACHIBOWLI_RADIUS_KM=5

# Grid resolution for heatmap (degrees)
HEATMAP_GRID_RESOLUTION=0.003

# Crime data decay window (days)
CRIME_DECAY_DAYS=30

# Background job interval (minutes)
BACKGROUND_JOB_INTERVAL_MINUTES=5

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================

# Enable debug mode (never use in production!)
DEBUG=true

# Enable CORS in development
DEV_CORS_ENABLED=true

# Database reset on startup (development only)
RESET_DB_ON_STARTUP=false
